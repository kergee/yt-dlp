{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yt-dlp-tauri",
  "version": "0.1.5",
  "identifier": "com.chlience.ytdlptauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "yt-dlp-tauri",
        "width": 1180,
        "height": 740,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://*.ytimg.com https://*.youtube.com https://*.googlevideo.com https://*.bilibili.com https://*.hdslb.com https://*.bilivideo.com data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' https://ipc.localhost; connect-src ipc: http://ipc.localhost https://api.github.com https://*.bilibili.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "resources": [
      "tools-manifest.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
